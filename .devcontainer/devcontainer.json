{
  "name": "ma-robot-sim-ros2-jazzy",

  // Default is portable and uses noVNC for GUI apps.
  // For WSLg GUI, add: "docker-compose.wslg.yml"
  // For NVIDIA GPU, add: "docker-compose.nvidia.yml"
  "dockerComposeFile": [
    "docker-compose.yml",
    "docker-compose.wslg.yml",
    "docker-compose.nvidia.yml"
  ],

  "service": "ma-robot-sim",
  "workspaceFolder": "/mt-mohamad-nassif",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "shutdownAction": "stopCompose",

  "forwardPorts": [6080, 8080, 10000],
  "portsAttributes": {
    "6080": {
      "label": "noVNC desktop"
    },
    "8080": {
      "label": "optional web visualizer"
    },
    "10000": {
      "label": "Unity ROS-TCP endpoint"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-python.python",
        "twxs.cmake",
        "eamodio.gitlens",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.watcherExclude": {
          "**/build/**": true,
          "**/install/**": true,
          "**/log/**": true,
          "**/.git/objects/**": true
        },
        "cmake.configureOnOpen": false,
        "ros.distro": "jazzy"
      }
    }
  },

  "postCreateCommand": "rosdep update || true",
  "postAttachCommand": "bash -lc 'source /opt/ros/jazzy/setup.bash && echo ROS_DISTRO=$ROS_DISTRO && echo WORKSPACE=/mt-mohamad-nassif'"
}
